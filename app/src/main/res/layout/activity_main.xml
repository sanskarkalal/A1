<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp">

    <TextView
        android:id="@+id/textViewAttractions"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/attractions_description"
        android:textSize="16sp"
        android:gravity="center"
        android:layout_marginBottom="8dp"/>

    <Button
        android:id="@+id/buttonAttractions"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/attractions_button"
        android:layout_marginBottom="32dp"/>

    <TextView
        android:id="@+id/textViewRestaurants"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/restaurants_description"
        android:textSize="16sp"
        android:gravity="center"
        android:layout_marginBottom="8dp"/>

    <Button
        android:id="@+id/buttonRestaurants"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/restaurants_button"/>

</LinearLayout>